# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API (Supabase is the primary runtime store)
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000,https://your-existing-app.vercel.app
DEMO_MODE=false
RATE_LIMIT_MAX=120

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Intelligence worker
LLM_API_KEY=
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
LLM_TEXT_MODEL=Qwen/Qwen3-Omni-30B-A3B-Instruct
LLM_VISION_MODEL=Qwen/Qwen3-Omni-30B-A3B-Instruct
LLM_AUDIO_MODEL=FunAudioLLM/SenseVoiceSmall
TAVILY_API_KEY=
TAVILY_API_BASE_URL=https://api.tavily.com
WORKER_CONCURRENCY=8
WORKER_POLL_INTERVAL_MS=1000

# Internal service authentication (server-only)
# Generate a different random value from WECHAT_CREDENTIAL_ENCRYPTION_KEY.
TOMEET_INTERNAL_API_TOKEN=
TOMEET_API_URL=http://localhost:4000

# WeChat transport: Tencent iLink onboarding + Railway worker (server-only)
# Generate once: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Set the exact same value on the API and wechat-ilink-worker services.
WECHAT_CREDENTIAL_ENCRYPTION_KEY=
WECHAT_WORKER_CONCURRENCY=8
WECHAT_WORKER_CLAIM_INTERVAL_MS=1000
# Optional for protocol testing; production should keep the official default.
# WECHAT_ILINK_QR_BASE_URL=https://ilinkai.weixin.qq.com
